# Copy this file to .env and fill in your own values.
# The .env file is gitignored and should never be committed.

# Secret key used by Flask for session signing and CSRF protection.
# Generate a strong one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-to-a-random-secret

# Database connection string.
# Default (SQLite) is used if this is omitted.
# Examples:
#   sqlite:///expense_tracker.db
#   postgresql://user:password@localhost:5432/expense_tracker
DATABASE_URL=sqlite:///expense_tracker.db

# Toggle Flask debug mode (True for development, False for production).
FLASK_DEBUG=True
